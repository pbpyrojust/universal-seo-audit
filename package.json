{
  "name": "universal-seo-audit",
  "private": true,
  "type": "module",
  "version": "0.4.0",
  "description": "Technical SEO audit CLI for development, staging, protected, and noindex sites using Playwright. Phase 3 adds structured data, hreflang/lang/viewport, and lightweight render diagnostics.",
  "author": "Justin Adams (https://justwhat.net)",
  "license": "MIT",
  "scripts": {
    "audit": "node scripts/run-seo-audit.mjs --site https://www.example.com",
    "audit:slow": "node scripts/run-seo-audit.mjs --site https://www.example.com --slow --respect-robots --cloudflare-aware",
    "build:urls": "node scripts/build-urls-from-sitemap.mjs --site https://www.example.com --out scripts/urls.txt",
    "scan:urls": "node scripts/seo-audit.mjs --urls-file scripts/urls.txt --out-dir reports",
    "report": "node scripts/generate-seo-report.mjs --run-dir reports/latest",
    "tickets": "node scripts/generate-seo-tickets.mjs --run-dir reports/latest",
    "cli": "node bin/universal-seo-audit.mjs",
    "sitemap:xml-to-urls": "node scripts/convert-sitemap-xml-to-urls.mjs"
  },
  "dependencies": {
    "csv-stringify": "^6.6.0",
    "playwright": "^1.57.0"
  },
  "packageManager": "pnpm@10"
}